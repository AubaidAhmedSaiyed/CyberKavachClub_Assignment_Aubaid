generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  FACULTY_COORDINATOR
  STUDENT_COORDINATOR
  TECH_COORDINATOR
  CONTENT_COORDINATOR
  SOCIAL_MEDIA_COORDINATOR
  CLUB_MEMBER
  GUEST
}

model User {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  email            String   @unique
  password         String
  firstName        String
  lastName         String
  studentId        String?  @unique
  role             Role     @default(GUEST)
  isApproved       Boolean  @default(false)
  points           Int      @default(0)
  profileImage     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  notificationPrefs Json?    // e.g., { email: true, push: true }

  requestsCreated  Request[] @relation("RequestCreator")
  teams            TeamMember[]
  attendances      Attendance[]
  notifications    Notification[]
  waitlists        Waitlist[]
  registrations    EventRegistration[]
  auditLogs        AuditLog[]
  badges           UserBadge[]
  pointHistory     PointHistory[]
  feedbacks        EventFeedback[]
}

model Event {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  description         String
  venue               String
  date                DateTime
  time                String
  rules               String[]
  tags                String[]
  categories          String[]
  teamSize            Int      @default(1)
  capacity            Int      @default(100)
  registrationDeadline DateTime
  bannerImage         String?
  isPublished         Boolean  @default(false)
  isArchived          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  certificateTemplateId String?  @db.ObjectId

  requests            Request[]
  attendances         Attendance[]
  waitlists           Waitlist[]
  registrations       EventRegistration[]
  feedbacks           EventFeedback[]
  certificateTemplate CertificateTemplate? @relation(fields: [certificateTemplateId], references: [id])
}

enum RequestStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum RequestType {
  EVENT_PERMISSION
  BUDGET_APPROVAL
  VENUE_REQUEST
  SOCIAL_MEDIA_APPROVAL
  CONTENT_PUBLISHING
  CERTIFICATE_AUTHORIZATION
  EXTERNAL_COLLABORATION
}

model Request {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  description    String
  type           RequestType
  status         RequestStatus @default(PENDING)
  creatorId      String        @db.ObjectId
  eventId        String?       @db.ObjectId
  remarks        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  creator        User          @relation("RequestCreator", fields: [creatorId], references: [id])
  event          Event?        @relation(fields: [eventId], references: [id])
}

model Team {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  teamId         String        @unique // Auto-generated e.g. TEAM-1234
  name           String
  qrCode         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  members        TeamMember[]
}

model TeamMember {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId         String   @db.ObjectId
  userId         String   @db.ObjectId
  isLeader       Boolean  @default(false)
  joinedAt       DateTime @default(now())

  team           Team     @relation(fields: [teamId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
}

model Attendance {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  eventId        String   @db.ObjectId
  checkInTime    DateTime @default(now())
  checkOutTime   DateTime?
  status         String   @default("PRESENT") // LATE, PRESENT
  scannedBy      String?  @db.ObjectId // ID of coordinator who scanned

  user           User     @relation(fields: [userId], references: [id])
  event          Event    @relation(fields: [eventId], references: [id])
}

model Notification {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  title          String
  message        String
  type           String   @default("SYSTEM") // SYSTEM, APPROVAL, REMINDER
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])
}

model EventRegistration {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  eventId   String   @db.ObjectId
  status    String   @default("REGISTERED") // REGISTERED, CANCELLED
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
}

model Waitlist {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  eventId   String   @db.ObjectId
  position  Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
}

model CertificateTemplate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  background  String   // URL to image
  textConfig  Json     // { x, y, font, color, etc }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  events      Event[]
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
}

model Badge {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  icon        String
  description String
  createdAt   DateTime @default(now())

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  badgeId   String   @db.ObjectId
  awardedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])
}

model PointHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  points    Int
  reason    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model EventFeedback {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  eventId   String   @db.ObjectId
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
}
